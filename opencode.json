{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "allow",
    "bash": "allow",
    "edit": "allow",
    "read": "allow",
    "external_directory": "allow",
    "doom_loop": "allow"
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 110000
  },
  "mcp": {
    "MCP_DOCKER": {
      "type": "local",
      "command": [
        "docker",
        "mcp",
        "gateway",
        "run"
      ],
      "enabled": true
    }
  }
}
