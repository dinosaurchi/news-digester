APP_PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sme_news
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change-me-in-production
DEBUG=true

# Initial/dev administrator. On startup, the backend creates this user when
# the users table is empty. Change these before deploying anywhere shared.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
ADMIN_DISPLAY_NAME=Admin
ADMIN_ROLE=admin

# OpenCode Server
OPENCODE_SERVER_IMAGE=ghcr.io/anomalyco/opencode:latest
OPENCODE_SERVER_PORT=4096
OPENCODE_SERVER_USERNAME=opencode
OPENCODE_SERVER_PASSWORD=changeme
OPENCODE_CONFIG_DIR=/opencode/config
OPENCODE_DEFAULT_MODEL=opencode/gpt-5-nano
OPENCODE_DEFAULT_AGENT=general

# OpenCode Agent Adapter
OPENCODE_ADAPTER_IMAGE=sme-news-admin-opencode-agent-adapter:latest
OPENCODE_ADAPTER_PORT=8080
MODEL_CATALOG_OVERRIDE=opencode/gpt-5-nano
AGENT_CATALOG_OVERRIDE=general

# OpenCode Backend Configuration
OPENCODE_BASE_URL=http://opencode-agent-adapter:8080
OPENCODE_TIMEOUT_SECONDS=60
OPENCODE_ENABLED=false
OPENCODE_DEFAULT_MODEL=opencode/gpt-5-nano
OPENCODE_DEFAULT_AGENT=general
OPENCODE_WORKSPACE_DIR=/workspace
